+void threadinfo::destroy(threadinfo* ti) {
+    if (!ti)
+        return;
+
+    threadinfo** pnext = &allthreads;
+    while (*pnext && *pnext != ti)
+        pnext = &(*pnext)->next_;
+    if (*pnext == ti)
+        *pnext = ti->next_;
+
+    limbo_group* lg = ti->limbo_head_;
+    while (lg) {
+        limbo_group* next = lg->next_;
+        ti->deallocate(lg, sizeof(limbo_group), memtag_limbo);
+        lg = next;
+    }
+
+    pool_allocation* pa = ti->pool_allocations_;
+    while (pa) {
+        pool_allocation* next = pa->next;
+        if (pa->use_mmap)
+            munmap(pa->base, pa->size);
+        else
+            free(pa->base);
+        free(pa);
+        pa = next;
+    }
+
+    ti->~threadinfo();
+    free(ti);
+}
