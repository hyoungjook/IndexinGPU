+    remember_pool_allocation(pool, pool_size, pool_uses_mmap);
     initialize_pool(pool, pool_size, nl * CACHE_LINE_SIZE);
     pool_[nl - 1] = pool;
 }
+
+void threadinfo::remember_pool_allocation(void* base, size_t size, bool use_mmap) {
+    pool_allocation* pa = static_cast<pool_allocation*>(malloc(sizeof(pool_allocation)));
+    if (!pa) {
+        fprintf(stderr, "malloc: out of memory\n");
+        abort();
+    }
+    pa->base = base;
+    pa->size = size;
+    pa->use_mmap = use_mmap;
+    pa->next = pool_allocations_;
+    pool_allocations_ = pa;
+}
